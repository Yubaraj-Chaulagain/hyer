<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Offline Cashbook</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; max-width: 600px; margin: auto; }
    h1 { text-align: center; }
    input, button { padding: 8px; margin: 5px 0; width: 100%; box-sizing: border-box; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    table, th, td { border: 1px solid #ccc; }
    th, td { padding: 8px; text-align: center; }
    .offline { color: red; }
    .online { color: green; }
  </style>
</head>
<body>

<h1>Offline Cashbook</h1>
<p>Status: <span id="status"></span></p>

<input type="date" id="date" placeholder="Date" />
<input type="number" id="amount" placeholder="Amount" />
<input type="text" id="description" placeholder="Description" />
<button onclick="addEntry()">Add Entry</button>

<table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Amount</th>
      <th>Description</th>
    </tr>
  </thead>
  <tbody id="entries">
  </tbody>
</table>

<script>
const statusEl = document.getElementById('status');
const entriesEl = document.getElementById('entries');
const STORAGE_KEY = 'offlineCashbook';

// Replace with your Apps Script Web App URL
const WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbyOlLVFxH34xR5tndDGpAN-l88XMnb8oXZRvgdvfBwDPZtplrneFBOuJHEDMYwJ5Nan/exec';

// Update online/offline status
function updateStatus() {
  if(navigator.onLine) {
    statusEl.textContent = 'Online';
    statusEl.className = 'online';
    syncDataToGoogleSheet();
  } else {
    statusEl.textContent = 'Offline';
    statusEl.className = 'offline';
  }
}

// Load entries from localStorage
function loadEntries() {
  const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  entriesEl.innerHTML = '';
  data.forEach(entry => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td>${entry.date}</td><td>${entry.amount}</td><td>${entry.description}</td>`;
    entriesEl.appendChild(tr);
  });
}

// Add new entry
function addEntry() {
  const date = document.getElementById('date').value;
  const amount = document.getElementById('amount').value;
  const description = document.getElementById('description').value;

  if(!date || !amount || !description) { alert('Fill all fields'); return; }

  const newEntry = { date, amount, description };
  const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  data.push(newEntry);
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));

  document.getElementById('date').value = '';
  document.getElementById('amount').value = '';
  document.getElementById('description').value = '';

  loadEntries();
  if(navigator.onLine) syncDataToGoogleSheet();
}

// Sync offline data to Google Sheet
async function syncDataToGoogleSheet() {
  const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  if(data.length === 0) return;

  try {
    const response = await fetch(WEB_APP_URL, {
      method: 'POST',
      body: JSON.stringify({ entries: data }),
      headers: { "Content-Type": "application/json" }
    });
    const result = await response.json();
    if(result.success) {
      localStorage.removeItem(STORAGE_KEY);
      loadEntries();
      console.log('Data synced successfully!');
    }
  } catch(err) {
    console.log('Sync failed. Will retry when online.', err);
  }
}

// Detect online/offline
window.addEventListener('online', updateStatus);
window.addEventListener('offline', updateStatus);

// Initial load
updateStatus();
loadEntries();
</script>

</body>
</html>