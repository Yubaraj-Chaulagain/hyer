<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#2563eb">

<title>Offline Cashbook</title>
    <style>
.match{
  width:100%;
  min-height:100vh;
  overflow:auto;
  padding:10px;
  box-sizing:border-box;
}

input, select {
  width: 100%;
  box-sizing: border-box;
  padding: 10px;
  margin: 5px 0;
  font-size: 16px;
}

/* BUTTONS */
button{
  width:auto;                 /* 🔥 fix */
  padding:8px 14px;
  margin:5px 3px;
  background:#2563eb;
  color:#fff;
  border:none;
  border-radius:6px;
  font-size:13px;
  cursor:pointer;
}

/* SMALL TABLE BUTTONS */
td button{
  padding:4px 8px;
  font-size:11px;
}

/* TABLE */
table{
  width:100%;
  border-collapse:collapse;
  font-family:arial;
}

th,td{
  border:1px solid #2563eb;
  padding:10px;
  text-align:left;
  word-break:break-word;
}

th{
  background-color:#ffe066;
}

/* ROW STYLES */
tr:nth-child(even){
